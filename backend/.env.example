# Cloudflare Workers AI
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_MODEL=@cf/meta/llama-3.1-8b-instruct-fast
CF_MODEL_SMALL=@cf/meta/llama-3.2-3b-instruct

# База данных (SQLite) и CORS
DB_PATH=data/easy_week.db
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
CF_MODEL_MENU=@cf/mistralai/mistral-small-3.1-24b-instruct
CF_MODEL_JUDGE=@cf/mistralai/mistral-small-3.1-24b-instruct
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Gemini (Google AI Studio) — одна из выбираемых моделей рецептов
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
